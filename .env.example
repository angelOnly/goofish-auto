# OpenAI 兼容接口。
OPENAI_API_KEY=''
OPENAI_BASE_URL='https://your-openai-compatible-endpoint/v1'
OPENAI_MODEL_NAME=''

# 闲鱼热点任务 API。当前接口按你提供的说明不强制 Token；如你的部署
# 在反向代理层增加了鉴权，再填写 GOOFISH_API_TOKEN。
GOOFISH_API_BASE_URL=https://goofish.xiaolicloud.cn:18443
GOOFISH_API_TOKEN=
GOOFISH_API_TIMEOUT=30
GOOFISH_POLL_SECONDS=2
GOOFISH_MAX_WAIT_SECONDS=1800

# 后续接百度网盘时使用；本地原型不会自动上传远程文件。
BAIDU_NETDISK_ACCESS_TOKEN=
BAIDU_NETDISK_APP_KEY=

# TheItzy 会员页链接抓取。只在 tasks.json 开启 fetch_member_delivery，
# 且 rights_confirmed=true 后才会把会员页中的百度网盘链接写入发货信息。
# 不要把 Cookie 发到聊天里；只放在本机 .env。
# Docker Compose 读取 .env 时会处理 $变量，真实 Cookie 建议用单引号包起来。
THEITZY_COOKIE=''
